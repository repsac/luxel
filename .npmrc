# vite 8 is newer than what @vitejs/plugin-react@4.7's peer range allows. The
# combination works at runtime — vite's plugin API hasn't changed in a way that
# breaks plugin-react — so we tell npm to treat peer dependencies as advisory
# rather than fatal. Revisit when plugin-react publishes a release that lists
# vite 8 in its peers (then this file can be removed).
legacy-peer-deps=true
