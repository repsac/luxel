    "shader": {
      "language": "glsl",
      "source": "// Raw GLSL — you own main(). The prelude supplies:\n//   in  vec2 v_uv;        // [0,0] bottom-left, [1,1] top-right\n//   out vec4 outColor;\n//   + uniforms (iResolution, iTime, iCameraPosition, ...)\n\nvoid main() {\n    vec2 uv = v_uv;\n    outColor = vec4(uv.x, uv.y, 0.35 + 0.25 * sin(iTime), 1.0);\n}\n",
