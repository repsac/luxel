{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Luxel",
  "version": "0.1.0",
  "identifier": "com.edcaspersen.Luxel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Luxel",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local GLSL shader workbench",
    "longDescription": "Luxel is a developer-focused, local GLSL shader editor and single-frame renderer."
  }
}
